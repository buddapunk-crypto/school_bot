        s = c.fetchone()
        if s and s[0] > 0:
            acc = (s[1]/s[0]*100)
            bot.send_message(user_id, f"📊 Статистика:\n✅ Всего: {s[0]}\n✓ Верно: {s[1]}\n📈 Точность: {acc:.1f}%\n🔥 Серия: {s[2]}")
        else:
            bot.send_message(user_id, "Пока нет статистики. Пройди тест!")
    
    elif text == '🎲 Случайный':
        send_question(user_id, None)
    
    elif user_id in user_sessions and user_sessions[user_id].get('waiting'):
        check_answer(message)

def send_question(user_id, topic):
    q = generate_question(topic)
    user_sessions[user_id] = {'q': q, 'waiting': True}
    
    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
    markup.add('❌ Закончить')
    
    text = f"📚 {q['topic']}\n\n❓ {q['question']}\n\n"
    for i, opt in enumerate(q['options'], 1):
        text += f"{i}. {opt}\n"
    text += "\n✏️ Напиши номер ответа (1-4)"
    
    bot.send_message(user_id, text, reply_markup=markup)

def check_answer(message):
    user_id = message.from_user.id
    q = user_sessions[user_id]['q']
    answer = message.text.strip()
    
    # Определяем ответ
    if answer.isdigit() and 1 <= int(answer) <= 4:
        user_answer = q['options'][int(answer)-1]
    else:
        user_answer = answer
    
    correct = q['correct_answer']
    is_correct = user_answer.lower() == correct.lower()
    
    # Сохраняем результат
    c.execute("UPDATE stats SET total=total+1, correct=correct+?, streak=CASE WHEN ?=1 THEN streak+1 ELSE 0 END WHERE user_id=?", 
              (1 if is_correct else 0, 1 if is_correct else 0, user_id))
    conn.commit()
    
    if is_correct:
        response = f"✅ Правильно!\n\n{q.get('explanation', 'Молодец!')}"
    else:
        response = f"❌ Неправильно!\nПравильный ответ: {correct}\n\n{q.get('explanation', 'Повтори тему')}"
    
    markup = types.InlineKeyboardMarkup(row_width=2)
    markup.add(
        types.InlineKeyboardButton('➡️ Далее', callback_data='next'),
        types.InlineKeyboardButton('❌ Стоп', callback_data='stop')
    )
    
    bot.send_message(user_id, response, reply_markup=markup)
    user_sessions[user_id]['waiting'] = False

@bot.callback_query_handler(func=lambda c: True)
def callback(c):
    user_id = c.from_user.id
    
    if c.data.startswith('topic_'):
        topics = {'topic_ss': 'Системы счисления', 'topic_py': 'Python', 'topic_algo': 'Алгоритмы', 
                 'topic_net': 'Сети', 'topic_rand': None}
        topic = topics.get(c.data)
        bot.edit_message_text("🔄 Генерирую...", c.message.chat.id, c.message.message_id)
        send_question(user_id, topic)
    
    elif c.data.startswith('explain_'):
        topics = {'explain_ss': 'Системы счисления', 'explain_py': 'Python', 'explain_algo': 'Алгоритмы'}
        topic = topics.get(c.data)
        bot.edit_message_text(f"📖 Объясняю {topic}...", c.message.chat.id, c.message.message_id)
        
        explanation = ask_deepseek(f"Объясни {topic} простыми словами, с примерами")
        if explanation:
            bot.send_message(user_id, f"📚 {topic}\n\n{explanation}")
        else:
            bot.send_message(user_id, "😔 Ошибка, попробуй позже")
    
    elif c.data == 'next':
        if user_id in user_sessions:
            topic = user_sessions[user_id].get('q', {}).get('topic')
            send_question(user_id, topic)
    
    elif c.data == 'stop':
        if user_id in user_sessions:
            del user_sessions[user_id]
        markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
        markup.add('📝 Тест', '📚 Темы', '📊 Статистика', '❓ Объясни', '🎲 Случайный')
        bot.send_message(user_id, "✅ Тест завершен!", reply_markup=markup)
    
    bot.answer_callback_query(c.id)

