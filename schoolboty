def get_text(user_id, key, **kwargs):
    """Получение текста на языке пользователя"""
    c.execute("SELECT language FROM users WHERE user_id=?", (user_id,))
    result = c.fetchone()
    lang = result[0] if result else 'ru'
    
    text = translations.get(lang, translations['ru']).get(key, key)
    return text.format(**kwargs) if kwargs else text

# Декоратор для безопасного вызова функций
def safe_bot_call(func):
    def wrapper(*args, **kwargs):
        try:
            return func(*args, **kwargs)
        except Exception as e:
            logger.error(f"Ошибка в {func.__name__}: {e}", exc_info=True)
            try:
                message = args[0] if args else None
                if message and hasattr(message, 'chat'):
                    bot.send_message(message.chat.id, get_text(message.from_user.id, 'error'))
            except:
                pass
    return wrapper

# Функция вызова DeepSeek с повторными попытками
def ask_deepseek(prompt, retries=3):
    headers = {
        "Authorization": f"Bearer {DEEPSEEK_API_KEY}", 
        "Content-Type": "application/json"
    }
    
    # Более конкретный промпт для получения JSON
    enhanced_prompt = f"""Ты - помощник для создания учебных тестов. Сгенерируй вопрос по указанной теме.
    
{prompt}

ВАЖНО: Ответ должен быть ТОЛЬКО в формате JSON, без дополнительного текста. 
Пример формата:
{{
    "question": "Текст вопроса",
    "options": ["Вариант 1", "Вариант 2", "Вариант 3", "Вариант 4"],
    "correct_answer": "Вариант 1",
    "explanation": "Объяснение правильного ответа"
}}"""
    
    payload = {
        "model": "deepseek-reasoner",
        "messages": [{"role": "user", "content": enhanced_prompt}],
        "temperature": 0.7,
        "max_tokens": 500
    }
    
    for attempt in range(retries):
        try:
            logger.debug(f"Отправка запроса к API (попытка {attempt + 1})")
            resp = requests.post(DEEPSEEK_API_URL, headers=headers, json=payload, timeout=30)
            
            logger.debug(f"Статус ответа: {resp.status_code}")
            
            if resp.status_code == 200:
                data = resp.json()
                content = data["choices"][0]["message"]["content"]
                logger.debug(f"Получен ответ от API: {content[:200]}...")
                return content
            elif resp.status_code == 429:
                wait_time = 2 ** attempt
                logger.warning(f"Превышен лимит запросов. Ожидание {wait_time} сек...")
                time.sleep(wait_time)
                continue
            else:
                logger.error(f"Ошибка API: {resp.status_code} - {resp.text}")
                
        except requests.exceptions.Timeout:
            logger.warning(f"Таймаут запроса (попытка {attempt + 1})")
        except requests.exceptions.ConnectionError:
            logger.warning(f"Ошибка соединения (попытка {attempt + 1})")
        except Exception as e:
            logger.error(f"Неизвестная ошибка: {e}")
            
        if attempt < retries - 1:
            time.sleep(2)
    
    return None

# Валидация вопроса
def validate_question(question):
    required_fields = ['question', 'options', 'correct_answer', 'explanation']
    
    if not all(field in question for field in required_fields):
        missing = [field for field in required_fields if field not in question]
        logger.warning(f"Отсутствуют поля: {missing}")
        return False
    
    if not isinstance(question['options'], list):
        logger.warning("options не является списком")
        return False
    
    if len(question['options']) != 4:
        logger.warning(f"Неверное количество опций: {len(question['options'])}")
        return False
    
    if question['correct_answer'] not in question['options']:
        logger.warning(f"Правильный ответ '{question['correct_answer']}' не найден в опциях")
        return False
    
    return True

# Генерация вопроса
def generate_question(topic=None):
    topics = ["Системы счисления", "Python", "Алгоритмы", "Сети", "Базы данных"]
    if not topic:
        topic = random.choice(topics)
    
    logger.info(f"Генерация вопроса по теме: {topic}")
    
    # База данных резервных вопросов
    backup_questions = {
        "Системы счисления": {
            "question": "Какая система счисления используется в компьютерах?",
            "options": ["Двоичная", "Десятичная", "Восьмеричная", "Шестнадцатеричная"],
            "correct_answer": "Двоичная",
            "explanation": "Компьютеры используют двоичную систему счисления (0 и 1), так как это легко реализовать электронно.",
            "topic": "Системы счисления"
        },
        "Python": {
            "question": "Какой оператор используется для проверки условия в Python?",
            "options": ["if", "for", "while", "switch"],
            "correct_answer": "if",
            "explanation": "Оператор if используется для условного выполнения кода в Python.",
            "topic": "Python"
        },
        "Алгоритмы": {
            "question": "Какой алгоритм сортировки имеет сложность O(n log n) в среднем случае?",
            "options": ["Быстрая сортировка", "Пузырьковая сортировка", "Сортировка вставками", "Сортировка выбором"],
            "correct_answer": "Быстрая сортировка",
            "explanation": "Быстрая сортировка имеет среднюю сложность O(n log n), в то время как пузырьковая - O(n²).",
            "topic": "Алгоритмы"
        },
        "Сети": {
            "question": "Какой протокол используется для передачи веб-страниц?",
            "options": ["HTTP", "FTP", "SMTP", "POP3"],
            "correct_answer": "HTTP",
            "explanation": "HTTP (HyperText Transfer Protocol) используется для передачи веб-страниц.",
            "topic": "Сети"
        },
        "Базы данных": {
            "question": "Какой язык используется для работы с реляционными базами данных?",
            "options": ["SQL", "Python", "Java", "HTML"],
            "correct_answer": "SQL",
            "explanation": "SQL (Structured Query Language) - язык структурированных запросов для работы с БД.",
            "topic": "Базы данных"
        }
    }
    
    prompt = f"""Создай тестовый вопрос по теме "{topic}".
    
Требования к вопросу:
1. Вопрос должен быть по информатике/программированию
2. 4 варианта ответа
3. Один правильный ответ
4. Краткое объяснение правильного ответа

Ответ предоставь ТОЛЬКО в формате JSON:
{{
    "question": "текст вопроса",
    "options": ["вариант 1", "вариант 2", "вариант 3", "вариант 4"],
    "correct_answer": "правильный вариант",
    "explanation": "объяснение"
}}"""
    
    response = ask_deepseek(prompt)
    
    if response:
        try:
            # Ищем JSON в ответе
            json_match = re.search(r'\{[^{}]*\{[^{}]*\}[^{}]*\}|\{[^{}]*\}', response, re.DOTALL)
            if json_match:
                json_str = json_match.group()
                logger.debug(f"Найден JSON: {json_str}")
                
                # Очищаем JSON от возможных проблем
                json_str = re.sub(r',\s*}', '}', json_str)  # Удаляем лишние запятые перед }
                json_str = re.sub(r',\s*]', ']', json_str)  # Удаляем лишние запятые перед ]
                
                question = json.loads(json_str)
                
                if validate_question(question):
                    question['topic'] = topic
                    logger.info(f"Успешно сгенерирован вопрос: {question['question'][:50]}...")
                    return question
                else:
                    logger.warning(f"Сгенерирован некорректный вопрос, используем резервный")
            else:
                logger.warning("JSON не найден в ответе API")
                logger.debug(f"Полный ответ: {response}")
        except json.JSONDecodeError as e:
            logger.error(f"Ошибка парсинга JSON: {e}")
        except Exception as e:
            logger.error(f"Неизвестная ошибка при парсинге: {e}")
    
    # Возвращаем резервный вопрос
    logger.info(f"Использую резервный вопрос по теме {topic}")
    return backup_questions.get(topic, backup_questions["Python"])

