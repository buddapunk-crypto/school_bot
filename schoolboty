def check_user_answer(message):
    """Проверяет ответ пользователя"""
    user_id = message.from_user.id
    
    if user_id not in user_sessions:
        bot.send_message(message.chat.id, "Начни новый тест через кнопку '📝 Начать тест'")
        return
    
    question_data = user_sessions[user_id]['current_question']
    user_answer = message.text.strip()
    
    bot.send_chat_action(message.chat.id, 'typing')
    
    # Получаем правильный ответ
    correct_answer = question_data.get('correct_answer', '')
    options = question_data.get('options', [])
    
    # Проверяем, является ли ответ номером варианта
    if user_answer.isdigit() and 1 <= int(user_answer) <= len(options):
        user_answer_text = options[int(user_answer) - 1]
    else:
        user_answer_text = user_answer
    
    # Проверяем ответ через DeepSeek
    check_result = deepseek.check_answer(
        question_data.get('question'),
        correct_answer,
        user_answer_text
    )
    
    is_correct = check_result.get('is_correct', False)
    
    # Сохраняем результат в БД
    conn = sqlite3.connect('test_bot.db')
    c = conn.cursor()
    
    c.execute('''INSERT INTO test_results 
                 (user_id, topic, question, user_answer, correct_answer, is_correct, timestamp)
                 VALUES (?, ?, ?, ?, ?, ?, ?)''',
              (user_id, 
               question_data.get('topic', 'Общее'),
               question_data.get('question'),
               user_answer_text,
               correct_answer,
               is_correct,
               datetime.now().isoformat()))
    
    # Обновляем статистику
    c.execute('''UPDATE user_stats 
                 SET total_questions = total_questions + 1,
                     correct_answers = correct_answers + ?,
                     current_streak = CASE WHEN ? = 1 THEN current_streak + 1 ELSE 0 END,
                     max_streak = CASE 
                        WHEN ? = 1 AND current_streak + 1 > max_streak 
                        THEN current_streak + 1 
                        ELSE max_streak 
                     END,
                     last_active = ?
                 WHERE user_id = ?''',
              (1 if is_correct else 0,
               1 if is_correct else 0,
               1 if is_correct else 0,
               datetime.now().isoformat(),
               user_id))
    
    conn.commit()
    conn.close()
    
    # Формируем ответ
    if is_correct:
        response = f"""
✅ ПРАВИЛЬНО!

{check_result.get('explanation', 'Отличный ответ!')}

💡 Интересный факт: {check_result.get('fact', 'Ты хорошо знаешь эту тему!')}
        """
    else:
        response = f"""
❌ НЕПРАВИЛЬНО

Правильный ответ: {correct_answer}

📝 Объяснение: {check_result.get('explanation', 'Внимательнее в следующий раз')}

💡 Подсказка: {check_result.get('hint', 'Повтори тему')}
        """
    
    # Кнопки для продолжения
    markup = types.InlineKeyboardMarkup(row_width=2)
    markup.add(
        types.InlineKeyboardButton('➡️ Следующий вопрос', callback_data='next_question'),
        types.InlineKeyboardButton('📊 Статистика', callback_data='show_stats'),
        types.InlineKeyboardButton('📚 Другая тема', callback_data='change_topic'),
        types.InlineKeyboardButton('❌ Закончить', callback_data='end_test')
    )
    
    bot.send_message(message.chat.id, response, reply_markup=markup)
    
    # Очищаем состояние ожидания
    del user_sessions[user_id]['waiting_answer']

def show_stats(message):
    """Показывает статистику пользователя"""
    user_id = message.from_user.id
    
    conn = sqlite3.connect('test_bot.db')
    c = conn.cursor()
    
    # Общая статистика
    c.execute('''SELECT total_questions, correct_answers, current_streak, max_streak 
                 FROM user_stats WHERE user_id = ?''', (user_id,))
    stats = c.fetchone()
    
    # Статистика по темам
    c.execute('''SELECT topic, COUNT(*) as total, 
                 SUM(CASE WHEN is_correct = 1 THEN 1 ELSE 0 END) as correct
                 FROM test_results 
                 WHERE user_id = ?
                 GROUP BY topic
                 ORDER BY total DESC
                 LIMIT 5''', (user_id,))
    topics_stats = c.fetchall()
    
    conn.close()
    
    if stats:
        total, correct, streak, max_streak = stats
        accuracy = (correct / total * 100) if total > 0 else 0
        
        text = f"""
📊 ТВОЯ СТАТИСТИКА

Всего вопросов: {total}
✅ Правильных: {correct}
❌ Неправильных: {total - correct}
📈 Точность: {accuracy:.1f}%
🔥 Текущая серия: {streak}
🏆 Рекордная серия: {max_streak}

📚 Топ тем:
"""
        
        if topics_stats:
            for topic, total_t, correct_t in topics_stats:
                topic_accuracy = (correct_t / total_t * 100) if total_t > 0 else 0
                text += f"• {topic}: {correct_t}/{total_t} ({topic_accuracy:.1f}%)\n"
        else:
            text += "• Пока нет данных. Пройди тест!"
        
        bot.send_message(message.chat.id, text)
    else:
        bot.send_message(message.chat.id, "У тебя пока нет статистики. Начни тест!")

