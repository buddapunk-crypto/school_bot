# Проверка ответа пользователя
def check_answer(message):
    user_id = message.from_user.id
    session = user_sessions.get(user_id)
    if not session:
        return
    
    question = session['q']
    user_answer_idx = message.text.strip()
    
    # Обновляем время ответа
    answer_time = time.time() - session.get('start_time', time.time())
    
    if user_answer_idx.isdigit() and 1 <= int(user_answer_idx) <= len(question['options']):
        user_answer = question['options'][int(user_answer_idx) - 1]
    else:
        user_answer = user_answer_idx
    
    correct_answer = question['correct_answer']
    is_correct = user_answer.lower() == correct_answer.lower()
    
    # Обновляем статистику
    c.execute("""
        UPDATE stats 
        SET total = total + 1, 
            correct = correct + ?, 
            streak = CASE WHEN ?=1 THEN streak+1 ELSE 0 END,
            last_active = ?,
            average_time = (average_time * (total) + ?) / (total + 1)
        WHERE user_id=?""", 
        (1 if is_correct else 0, 1 if is_correct else 0, 
         datetime.now().isoformat(), answer_time, user_id))
    
    # Обновляем прогресс по теме
    c.execute("""
        INSERT INTO topic_progress (user_id, topic, total_attempts, correct_answers, last_attempt)
        VALUES (?, ?, 1, ?, ?)
        ON CONFLICT(user_id, topic) DO UPDATE SET
            total_attempts = total_attempts + 1,
            correct_answers = correct_answers + ?,
            last_attempt = ?
        """, (user_id, question['topic'], 1 if is_correct else 0, 
              datetime.now().isoformat(), 1 if is_correct else 0, datetime.now().isoformat()))
    
    conn.commit()
    
    if is_correct:
        feedback = f"✅ Правильно!\n\n{question.get('explanation', 'Молодец!')}"
    else:
        feedback = f"❌ Неправильно.\nПравильный ответ: {correct_answer}.\n\n{question.get('explanation', 'Повтори тему.')}"
    
    markup = types.InlineKeyboardMarkup(row_width=2)
    markup.add(
        types.InlineKeyboardButton('➡️ Далее', callback_data='next'),
        types.InlineKeyboardButton('❌ Стоп', callback_data='stop')
    )
    
    bot.send_message(user_id, feedback, reply_markup=markup)
    user_sessions[user_id]['waiting'] = False

# Обработчик отзывов
def handle_feedback(message):
    user_id = message.from_user.id
    
    if message.text == '/cancel':
        user_sessions[user_id]['waiting_feedback'] = False
        bot.send_message(user_id, get_text(user_id, 'feedback_cancel'))
        return
    
    c.execute("INSERT INTO feedback (user_id, feedback, timestamp) VALUES (?, ?, ?)",
              (user_id, message.text, datetime.now().isoformat()))
    conn.commit()
    
    user_sessions[user_id]['waiting_feedback'] = False
    bot.send_message(user_id, get_text(user_id, 'feedback_thanks'))
    
    # Отправляем уведомление администратору
    if ADMIN_ID:
        try:
            bot.send_message(ADMIN_ID, 
                f"📬 Новый отзыв от @{message.from_user.username} (ID: {user_id}):\n\n{message.text}")
        except:
            pass

# Callback-обработчик
@bot.callback_query_handler(func=lambda call: True)
@safe_bot_call
def process_callback(call):
    user_id = call.from_user.id
    
    # Обработка сброса статистики
    if call.data == 'confirm_reset':
        c.execute("UPDATE stats SET total=0, correct=0, streak=0 WHERE user_id=?", (user_id,))
        c.execute("DELETE FROM topic_progress WHERE user_id=?", (user_id,))
        conn.commit()
        bot.edit_message_text(get_text(user_id, 'reset_success'), 
                             call.message.chat.id, call.message.message_id)
    
    elif call.data == 'cancel_reset':
        bot.edit_message_text(get_text(user_id, 'reset_cancel'), 
                             call.message.chat.id, call.message.message_id)
    
    # Обработка выбора темы для теста
    elif call.data.startswith('topic_'):
        topics_map = {
            'topic_ss': 'Системы счисления',
            'topic_py': 'Python',
            'topic_algo': 'Алгоритмы',
            'topic_net': 'Сети',
            'topic_db': 'Базы данных',
            'topic_rand': None
        }
        topic = topics_map.get(call.data)
        bot.edit_message_text(get_text(user_id, 'generating'), 
                            chat_id=call.message.chat.id, 
                            message_id=call.message.message_id)
        send_question(user_id, topic)
    
    # Обработка выбора темы для объяснения
    elif call.data.startswith('explain_'):
        topics_map = {
            'explain_ss': 'Системы счисления',
            'explain_py': 'Python',
            'explain_algo': 'Алгоритмы',
            'explain_net': 'Сети',
            'explain_db': 'Базы данных',
            'explain_oop': 'ООП'
        }
        topic = topics_map.get(call.data)
        bot.edit_message_text(f"📖 Объясняю {topic}...", 
                            chat_id=call.message.chat.id, 
                            message_id=call.message.message_id)
        
        explanation = ask_deepseek(f"Объясни {topic} простыми словами, с примерами. Ответ дай на русском языке.")
        if explanation:
            # Очищаем ответ от возможных JSON
            explanation = re.sub(r'\{.*\}', '', explanation, flags=re.DOTALL)
            bot.send_message(user_id, f"📚 {topic}\n\n{explanation}")
        else:
            bot.send_message(user_id, get_text(user_id, 'error'))
    
    # Обработка навигации по тесту
    elif call.data == 'next':
        if user_id in user_sessions:
            prev_topic = user_sessions[user_id].get('q', {}).get('topic')
            send_question(user_id, prev_topic)
    
    elif call.data == 'stop':
        if user_id in user_sessions:
            del user_sessions[user_id]
        markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
        markup.add('📝 Тест', '📚 Темы', '📊 Статистика', '❓ Объясни', '🎲 Случайный')
        bot.send_message(user_id, get_text(user_id, 'test_complete'), reply_markup=markup)
    
    bot.answer_callback_query(call.id)

