# Класс для работы с DeepSeek
class DeepSeekHelper:
    def __init__(self):
        self.api_key = DEEPSEEK_API_KEY
        self.api_url = DEEPSEEK_API_URL
    
    def generate_question(self, topic=None, difficulty="medium"):
        """Генерирует вопрос по информатике"""
        topics = [
            "Системы счисления", "Алгоритмы", "Python", 
            "Компьютерные сети", "Базы данных", "Кибербезопасность",
            "Операционные системы", "Логика", "Программирование"
        ]
        
        if not topic:
            topic = random.choice(topics)
        
        prompt = f"""Создай тестовый вопрос по информатике на тему '{topic}'.
        Уровень сложности: {difficulty}
        
        Формат ответа (строго JSON):
        {{
            "question": "текст вопроса",
            "options": ["вариант1", "вариант2", "вариант3", "вариант4"],
            "correct_answer": "правильный вариант (точно как в options)",
            "explanation": "объяснение ответа",
            "topic": "{topic}",
            "difficulty": "{difficulty}"
        }}
        
        Вопрос должен быть интересным и проверять понимание темы.
        """
        
        return self._call_deepseek(prompt)
    
    def check_answer(self, question, correct_answer, user_answer):
        """Проверяет ответ пользователя"""
        prompt = f"""Проверь ответ на вопрос по информатике:
        
        Вопрос: {question}
        Правильный ответ: {correct_answer}
        Ответ ученика: {user_answer}
        
        Оцени ответ и верни JSON:
        {{
            "is_correct": true/false,
            "explanation": "почему ответ правильный/неправильный",
            "hint": "подсказка (если ответ неправильный)",
            "fact": "интересный факт по теме"
        }}
        """
        
        return self._call_deepseek(prompt)
    
    def explain_topic(self, topic):
        """Объясняет тему простыми словами"""
        prompt = f"""Объясни тему '{topic}' по информатике простыми словами.
        
        Напиши объяснение, которое будет понятно школьнику.
        Используй примеры из жизни.
        Выдели основные понятия.
        
        Формат: просто текст, без JSON.
        """
        
        response = self._call_deepseek(prompt, json_response=False)
        return response
    
    def _call_deepseek(self, prompt, json_response=True):
        """Вызов DeepSeek API"""
        headers = {
            "Authorization": f"Bearer {self.api_key}",
            "Content-Type": "application/json"
        }
        
        payload = {
            "model": "deepseek-reasoner",
            "messages": [
                {"role": "system", "content": "Ты - опытный учитель информатики. Отвечаешь четко и по делу."},
                {"role": "user", "content": prompt}
            ],
            "temperature": 0.7,
            "max_tokens": 2000
        }
        
        try:
            response = requests.post(self.api_url, headers=headers, json=payload)
            response.raise_for_status()
            result = response.json()
            content = result["choices"][0]["message"]["content"]
            
            if json_response:
                # Ищем JSON в ответе
                json_match = re.search(r'\{.*\}', content, re.DOTALL)
                if json_match:
                    return json.loads(json_match.group())
                else:
                    return {"error": "No JSON in response", "text": content}
            else:
                return content
                
        except Exception as e:
            return {"error": str(e)} if json_response else f"Ошибка: {str(e)}"

