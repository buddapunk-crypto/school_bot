# Функция вызова DeepSeek
def ask_deepseek(prompt):
    headers = {"Authorization": f"Bearer {DEEPSEEK_API_KEY}", "Content-Type": "application/json"}
    payload = {
        "model": "deepseek-reasoner",
        "messages": [{"role": "user", "content": prompt}],
        "temperature": 0.7
    }
    try:
        r = requests.post(DEEPSEEK_API_URL, headers=headers, json=payload, timeout=20)
        return r.json()["choices"][0]["message"]["content"]
    except:
        return None

# Генерация вопроса
def generate_question(topic=None):
    topics = ["Системы счисления", "Python", "Алгоритмы", "Сети", "Базы данных"]
    if not topic:
        topic = random.choice(topics)
    
    prompt = f"""Создай тестовый вопрос по {topic}. 
    Формат JSON: {{"question":"...","options":["1","2","3","4"],"correct":"...","explanation":"..."}}"""
    
    response = ask_deepseek(prompt)
    if response:
        try:
            json_match = re.search(r'\{.*\}', response, re.DOTALL)
            if json_match:
                q = json.loads(json_match.group())
                q['topic'] = topic
                return q
        except:
            pass
    
    # Резервный вопрос
    return {
        "question": "Что такое алгоритм?",
        "options": ["Набор команд", "Устройство", "Программа", "Язык"],
        "correct_answer": "Набор команд",
        "explanation": "Алгоритм - это последовательность команд",
        "topic": topic
    }

