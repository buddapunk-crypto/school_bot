from aiogram import Bot, Dispatcher, F
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup
from aiogram.fsm.storage.memory import MemoryStorage
from aiogram.types import Message, CallbackQuery, ReplyKeyboardMarkup
from aiogram.filters.command import Command
from aiogram.filters import BaseFilter
from aiogram.utils.keyboard import ReplyKeyboardBuilder, KeyboardButton, InlineKeyboardBuilder, InlineKeyboardButton
from typing import Any
import sqlite3
import asyncio
from datetime import datetime, timedelta  # Добавлен timedelta

# Настройки бота
API_TOKEN = '8343120896:AAEBFxXWTtHBr7cVe6e6fSLAADkjlibCF9A'  # замените на ваш токен
storage = MemoryStorage()
bot = Bot(token=API_TOKEN)
dp = Dispatcher(storage=storage)

# Подключение к базе данных
conn = sqlite3.connect('homework.db', check_same_thread=False)
cursor = conn.cursor()

# Создание таблицы для хранения заданий
cursor.execute('''
    CREATE TABLE IF NOT EXISTS homework (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        subject TEXT,
        task TEXT,
        deadline TEXT
    );
''')
conn.commit()

# Группы состояний
class AddTask(StatesGroup):
    subject = State()
    task = State()
    deadline = State()

class EditTask(StatesGroup):
    select_field = State()  # Выбор поля для редактирования
    new_value = State()     # Новый введенный пользователем значение

# Начало разговора
@dp.message(Command("start"))
async def cmd_start(message: Message):
    await message.answer("Привет! Я твой помощник по учебе. Используй /help для списка команд.")

# Команда справки
@dp.message(Command("help"))
async def cmd_help(message: Message):
    await message.answer(
        "Доступные команды:\n"
        "/add_task - добавить новое задание\n"
        "/view_tasks - посмотреть список текущих заданий\n"
        "/edit_task - редактировать задание\n"
        "/delete_task - удалить задание"
    )

# Начнем добавлять задание
@dp.message(Command("add_task"))
async def cmd_add_task(message: Message, state: FSMContext):
    await state.set_state(AddTask.subject)
    await message.answer("Введите название предмета:")

# Получаем предмет
@dp.message(F.text, AddTask.subject)
async def process_subject(message: Message, state: FSMContext):
    await state.update_data(subject=message.text)
    await state.set_state(AddTask.task)
    await message.answer("Опишите задание:")

# Получаем описание задания
@dp.message(F.text, AddTask.task)
async def process_task(message: Message, state: FSMContext):
    await state.update_data(task=message.text)
    await state.set_state(AddTask.deadline)
    await message.answer("Введите срок сдачи (ДД.ММ.ГГГГ):")

# Получаем срок сдачи
@dp.message(F.text, AddTask.deadline)
async def process_deadline(message: Message, state: FSMContext):
    try:
        # Проверяем формат даты
        deadline_date = datetime.strptime(message.text, "%d.%m.%Y")
        deadline_str = deadline_date.strftime("%d.%m.%Y")
    except ValueError:
        await message.answer("Неверный формат даты. Используйте ДД.ММ.ГГГГ")
        return
    
    data = await state.get_data()
    subject = data["subject"]
    task = data["task"]

    cursor.execute(
        "INSERT INTO homework VALUES (NULL, ?, ?, ?, ?)",
        (message.from_user.id, subject, task, deadline_str)
    )
    conn.commit()
    await state.clear()
    await message.answer(f"Задание '{subject}' успешно добавлено!")

# Просмотр заданий
@dp.message(Command("view_tasks"))
async def cmd_view_tasks(message: Message):
    cursor.execute("SELECT * FROM homework WHERE user_id=?", (message.from_user.id,))
    rows = cursor.fetchall()
    if not rows:
        await message.answer("У вас нет активных заданий.")
    else:
        tasks_list = ""
        for row in rows:
            tasks_list += f"{row[0]}. {row[2]} - {row[3]}, Срок: {row[4]}\n"
        await message.answer(f"Ваши текущие задания:\n{tasks_list}")

# ✏️ Редактирование задания
@dp.message(Command("edit_task"))
async def cmd_edit_task(message: Message, state: FSMContext):
    cursor.execute("SELECT * FROM homework WHERE user_id=?", (message.from_user.id,))
    rows = cursor.fetchall()
    
    if not rows:
        await message.answer("У вас нет заданий для редактирования.")
        return
    
    await state.set_state(EditTask.select_field)
    
    # Сохраняем список заданий в состоянии
    tasks_dict = {}
    keyboard = []
    
    for row in rows:
        task_id = row[0]
        task_text = f"{row[2]}: {row[3][:20]}..."
        tasks_dict[str(task_id)] = task_text
        keyboard.append([f"ID: {task_id} - {row[2]}"])
    
    await state.update_data(available_tasks=tasks_dict)
    
    keyboard.append(["Отмена"])
    reply_markup = ReplyKeyboardMarkup(keyboard=keyboard, resize_keyboard=True, one_time_keyboard=True)
    await message.answer("Выберите задание для редактирования (укажите ID):", reply_markup=reply_markup)

@dp.message(F.text, EditTask.select_field)
async def process_select_field(message: Message, state: FSMContext):
    if message.text.lower() == "отмена":
        await state.clear()
        return await message.answer("Редактирование отменено.", reply_markup=ReplyKeyboardMarkup(remove_keyboard=True))
    
    # Извлекаем ID из сообщения
    try:
        if "ID:" in message.text:
            task_id = int(message.text.split("ID:")[1].split("-")[0].strip())
        else:
            task_id = int(message.text)
    except ValueError:
        await message.answer("Пожалуйста, укажите корректный ID задания.")
        return
    
    # Проверяем существование задания
    cursor.execute("SELECT * FROM homework WHERE id=? AND user_id=?", (task_id, message.from_user.id))
    task = cursor.fetchone()
    
    if not task:
        await message.answer("Задание с таким ID не найдено.")
        return
    
    await state.update_data(selected_task_id=task_id)
    
    # Показываем поля для редактирования
    keyboard = [
        ["Предмет"],
        ["Описание"],
        ["Дедлайн"],
        ["Отмена"]
    ]
    reply_markup = ReplyKeyboardMarkup(keyboard=keyboard, resize_keyboard=True, one_time_keyboard=True)
    await message.answer(f"Выберите поле для редактирования задания:\n"
                        f"Предмет: {task[2]}\n"
                        f"Описание: {task[3][:50]}...\n"
                        f"Дедлайн: {task[4]}", 
                        reply_markup=reply_markup)
    
    # Переходим к выбору нового значения
    await state.set_state(EditTask.new_value)

@dp.message(F.text, EditTask.new_value)
async def process_new_value(message: Message, state: FSMContext):
    if message.text.lower() == "отмена":
        await state.clear()
        return await message.answer("Редактирование отменено.", reply_markup=ReplyKeyboardMarkup(remove_keyboard=True))
    
    data = await state.get_data()
    task_id = data['selected_task_id']
    field = message.text.lower()
    
    field_mapping = {
        "предмет": "subject",
        "описание": "task",
        "дедлайн": "deadline"
    }
    
    if field not in field_mapping:
        await message.answer("Пожалуйста, выберите одно из предложенных полей.")
        return
    
    db_field = field_mapping[field]
    
    # Сохраняем выбранное поле в состоянии и запрашиваем новое значение
    await state.update_data(field_to_edit=db_field)
    
    # Для дедлайна показываем пример формата
    if field == "дедлайн":
        await message.answer(f"Введите новое значение для {field} (формат: ДД.ММ.ГГГГ):", 
                           reply_markup=ReplyKeyboardMarkup(remove_keyboard=True))
    else:
        await message.answer(f"Введите новое значение для {field}:", 
                           reply_markup=ReplyKeyboardMarkup(remove_keyboard=True))
    
    # Остаемся в этом состоянии для получения нового значения
    return

@dp.message(F.text)
async def process_field_value(message: Message, state: FSMContext):
    data = await state.get_data()
    field_to_edit = data.get('field_to_edit')
    task_id = data.get('selected_task_id')
    
    if not field_to_edit or not task_id:
        # Если нет данных о редактировании, игнорируем
        return
    
    new_value = message.text
    
    # Валидация для дедлайна
    if field_to_edit == "deadline":
        try:
            deadline_date = datetime.strptime(new_value, "%d.%m.%Y")
            new_value = deadline_date.strftime("%d.%m.%Y")
        except ValueError:
            await message.answer("Неверный формат даты. Используйте ДД.ММ.ГГГГ")
            return
    
    # Обновляем задание в базе данных
    cursor.execute(f"UPDATE homework SET {field_to_edit}=? WHERE id=? AND user_id=?", 
                   (new_value, task_id, message.from_user.id))
    conn.commit()
    
    await state.clear()
    await message.answer(f"Задание успешно обновлено!")

# ❌ Удаление задания
@dp.message(Command("delete_task"))
async def cmd_delete_task(message: Message):
    cursor.execute("SELECT * FROM homework WHERE user_id=?", (message.from_user.id,))
    rows = cursor.fetchall()
    if not rows:
        await message.answer("У вас нет активных заданий.")
    else:
        inline_kb = InlineKeyboardBuilder()
        for row in rows:
            button_text = f"{row[2]} ({row[4]})"
            inline_kb.add(InlineKeyboardButton(text=button_text, callback_data=f"del_{row[0]}"))
        inline_kb.adjust(1)
        
        await message.answer("Выберите задание для удаления:", reply_markup=inline_kb.as_markup())

@dp.callback_query(F.data.startswith("del_"))
async def delete_task_callback(callback: CallbackQuery):
    task_id = int(callback.data.split('_')[1])
    
    # Проверяем, принадлежит ли задание пользователю
    cursor.execute("SELECT * FROM homework WHERE id=? AND user_id=?", 
                   (task_id, callback.from_user.id))
    task = cursor.fetchone()
    
    if not task:
        await callback.answer("Задание не найдено!")
        return
    
    cursor.execute("DELETE FROM homework WHERE id=?", (task_id,))
    conn.commit()
    
    await callback.message.edit_text(f"Задание '{task[2]}' удалено.")
    await callback.answer()

# Функция для отправки уведомлений о дедлайнах
async def send_deadline_reminders():
    while True:
        await asyncio.sleep(1800)  # Проверка каждые 30 минут
        
        now = datetime.now()
        
        # Ищем задания с дедлайном в ближайшие 3 часа
        cursor.execute("SELECT * FROM homework WHERE deadline IS NOT NULL")
        all_tasks = cursor.fetchall()
        
        for task in all_tasks:
            try:
                deadline = datetime.strptime(task[4], "%d.%m.%Y")
                time_diff = deadline - now
                
                # Если дедлайн через 1-3 часа
                if timedelta(hours=1) <= time_diff <= timedelta(hours=3):
                    await bot.send_message(
                        task[1], 
                        f"⏰ Напоминание: задание '{task[2]}' нужно сдать через {int(time_diff.total_seconds()/3600)} час(а/ов).\n"
                        f"Дедлайн: {task[4]}"
                    )
            except (ValueError, TypeError):
                continue

# Основной цикл
async def main():
    # Запускаем задачу напоминаний в фоне
    asyncio.create_task(send_deadline_reminders())
    
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
